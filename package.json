{
  "name": "school-saas",
  "version": "0.1.0",
  "private": true,
  "main": "start-electron.js",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "electron-dev": "node start-electron.js",
    "electron-build": "next build --webpack && electron-builder"
  },
  "build": {
    "appId": "com.edusaas.school",
    "productName": "EduSaaS School",
    "files": [
      ".next/**/*",
      "node_modules/**/*",
      "public/**/*",
      "app/**/*",
      "lib/**/*",
      "components/**/*",
      "start-electron.js",
      "package.json",
      "next.config.mjs",
      "drizzle.config.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "arctic": "^3.7.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "drizzle-orm": "^0.38.4",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.2",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.30.4",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4"
  }
}
